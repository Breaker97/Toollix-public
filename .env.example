# =========================================================================
# Toollix.io - Environment Configuration Template
# Copy this file to `.env.local` or `.env` and fill in your credentials.
# =========================================================================

# --- DATABASE (MongoDB) ---
# A MongoDB connection string (Atlas or Local instance)
MONGODB_URI=mongodb://localhost:27017/toollix

# --- AUTHENTICATION (NextAuth.js & OAuth Providers) ---
# NextAuth / Auth.js security keys (Must be a cryptographically secure 32+ character string)
# You can generate one via: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_minimum_32_characters
AUTH_SECRET=your_auth_secret_minimum_32_characters

# Base URL of the application. Set to http://localhost:3000 for local development.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Credentials (for social logins)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- RATE LIMITING & CACHING (Upstash Redis) ---
# Upstash Redis connection parameters (used for rate-limiting api requests)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# --- CLOUD STORAGE (Google Cloud Storage - GCS) ---
# GCS Bucket configurations for persistent media uploads (optional, falls back to DB storage if unconfigured)
GCS_BUCKET_NAME=your_gcs_bucket_name
GCS_PROJECT_ID=your_gcs_project_id
GCS_CLIENT_EMAIL=your_gcs_client_email
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_gcs_private_key_here\n-----END PRIVATE KEY-----\n"

# --- ANALYTICS (PostHog) ---
# PostHog Project token and host configuration
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=your_posthog_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- MONITORING & ERROR TRACKING (Sentry) ---
# Sentry DSN configuration for error logs and diagnostics
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# --- EMAIL TRANSMISSION (SMTP Server Settings) ---
# NodeMailer configuration parameters (used for transactional notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Toollix" <support@toollix.io>

# --- SEARCH ENGINE OPTIMIZATION & INDEXING ---
# Google Indexing API Key for automatic URL submission
GOOGLE_INDEXING_API_KEY=your_google_indexing_api_key
# Bing IndexNow Api Key for instant web indexing
INDEXNOW_KEY=your_indexnow_api_key

# --- CREATIVE EDITOR SDK (CESDK) ---
# License key for the canvas studio designer. Use "trial" for development.
NEXT_PUBLIC_CESDK_LICENSE=trial

# --- MAINTENANCE & CRON ---
# Shared secret for authenticating cron jobs / administrative routes
CRON_SECRET=your_cron_secret
